# Copy this file to .env and fill in the values you actually use.
# You only need ONE of the two API keys, matching VISION_PROVIDER below.

# Which provider to use: "anthropic" or "openai"
VISION_PROVIDER=anthropic

# Anthropic (used if VISION_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI (used if VISION_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Rendering resolution for PDF -> image conversion (higher = more accurate,
# more tokens, slower, costlier). 150-200 is a good balance for price tables.
RENDER_DPI=175
